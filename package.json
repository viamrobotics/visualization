		"vitest": "3.2.4"
	},
	"peerDependencies": {
		"@ag-grid-community/client-side-row-model": ">=32.3.0",
		"@ag-grid-community/core": ">=32.3.0",
		"@ag-grid-community/styles": ">=32.3.0",
		"@dimforge/rapier3d-compat": ">=0.17",
		"@threlte/core": ">=8",
