{
	"name": "@viamrobotics/motion-tools",
	"version": "0.14.8",
	"description": "Motion visualization with Viam",
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"dev": "tsx server/check-bun && bun run server/server.ts",
		"build": "vite build && npm run prepack",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test:client": "go test ./client/... -count=1",
		"test": "pnpm test:unit -- --run",
		"test:e2e": "playwright test",
		"model-pipeline:run": "node scripts/model-pipeline.js",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@ag-grid-community/client-side-row-model": "32.3.9",
		"@ag-grid-community/core": "32.3.9",
		"@ag-grid-community/styles": "32.3.9",
		"@changesets/cli": "2.29.6",
		"@dimforge/rapier3d-compat": "0.18.2",
		"@eslint/compat": "1.3.2",
		"@eslint/js": "9.34.0",
		"@playwright/test": "1.55.0",
		"@sentry/sveltekit": "10.10.0",
		"@skeletonlabs/skeleton": "3.2.0",
		"@skeletonlabs/skeleton-svelte": "1.5.1",
		"@sveltejs/adapter-static": "3.0.9",
		"@sveltejs/kit": "2.37.0",
		"@sveltejs/package": "2.5.0",
		"@sveltejs/vite-plugin-svelte": "6.1.4",
		"@tailwindcss/forms": "0.5.10",
		"@tailwindcss/vite": "4.1.13",
		"@tanstack/svelte-query": "5.87.1",
		"@tanstack/svelte-query-devtools": "5.87.3",
		"@testing-library/jest-dom": "6.8.0",
		"@testing-library/svelte": "5.2.8",
		"@thi.ng/paths": "5.2.21",
		"@threlte/core": "8.1.5",
		"@threlte/extras": "9.5.4",
		"@threlte/rapier": "3.1.5",
		"@threlte/xr": "1.0.8",
		"@types/bun": "1.2.21",
		"@types/lodash-es": "4.17.12",
		"@types/three": "0.179.0",
		"@typescript-eslint/eslint-plugin": "8.42.0",
		"@typescript-eslint/parser": "8.42.0",
		"@viamrobotics/prime-core": "0.1.5",
		"@viamrobotics/sdk": "0.52.0",
		"@viamrobotics/svelte-sdk": "0.7.1",
		"@vitejs/plugin-basic-ssl": "2.1.0",
		"@zag-js/svelte": "1.22.1",
		"@zag-js/tree-view": "1.22.1",
		"camera-controls": "3.1.0",
		"eslint": "9.34.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.12.1",
		"globals": "16.3.0",
		"idb-keyval": "6.2.2",
		"jsdom": "26.1.0",
		"lodash-es": "4.17.21",
		"lucide-svelte": "0.542.0",
		"prettier": "3.6.2",
		"prettier-plugin-svelte": "3.4.0",
		"prettier-plugin-tailwindcss": "0.6.14",
		"publint": "0.3.12",
		"runed": "0.31.1",
		"svelte": "5.38.7",
		"svelte-check": "4.3.1",
		"svelte-virtuallists": "1.4.2",
		"tailwindcss": "4.1.13",
		"three": "0.179.0",
		"three-mesh-bvh": "^0.9.1",
		"threlte-uikit": "1.2.1",
		"tsx": "4.20.5",
		"type-fest": "^5.0.1",
		"typescript": "5.9.2",
		"typescript-eslint": "8.42.0",
		"vite": "7.1.4",
		"vite-plugin-devtools-json": "1.0.0",
		"vite-plugin-mkcert": "1.17.8",
		"vitest": "3.2.4"
	},
	"peerDependencies": {
		"@dimforge/rapier3d-compat": ">=0.17",
		"@tanstack/svelte-query": ">=5",
		"@threlte/core": ">=8",
		"@threlte/extras": ">=9",
		"@threlte/rapier": ">=3",
		"@threlte/xr": ">=1",
		"@viamrobotics/prime-core": ">=0.1",
		"@viamrobotics/sdk": ">=0.38",
		"@viamrobotics/svelte-sdk": ">=0.1",
		"@zag-js/svelte": ">=1",
		"@zag-js/tree-view": ">=1",
		"idb-keyval": ">=6",
		"lucide-svelte": ">=0.511",
		"runed": ">=0.28",
		"svelte": ">=5",
		"svelte-virtuallists": ">=1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"packageManager": "pnpm@10.14.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./lib": {
			"types": "./dist/lib.d.ts",
			"svelte": "./dist/lib.js"
		},
		"./test": {
			"types": "./dist/test.d.ts",
			"svelte": "./dist/test.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/viam-labs/motion-tools.git"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	]
}
