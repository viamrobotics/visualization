	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@sentry/cli",
			"@tailwindcss/oxide",
			"esbuild"
		]
	},
	"packageManager": "pnpm@10.14.0",
	"engines": {
		"node": ">=22.12.0"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./lib": {
			"types": "./dist/lib.d.ts",
			"svelte": "./dist/lib.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/viamrobotics/visualization.git"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"dependencies": {
		"@bufbuild/protobuf": "1.10.1",
		"@connectrpc/connect": "1.7.0",
		"@connectrpc/connect-web": "1.7.0",
		"@neodrag/svelte": "^2.3.3",
		"@tanstack/svelte-query-devtools": "^6.0.2",
		"earcut": "^3.0.2",
		"filtrex": "^3.1.0",
		"koota": "0.6.5",
		"lodash-es": "4.18.1",
		"three-mesh-bvh": "^0.9.8",
		"uuid-tool": "^2.0.3"
	}
}
