		"@sveltejs/vite-plugin-svelte": "6.1.4",
		"@tailwindcss/forms": "0.5.10",
		"@tailwindcss/vite": "4.1.13",
		"@testing-library/jest-dom": "6.8.0",
		"@testing-library/svelte": "5.2.8",
		"@testing-library/user-event": "^14.6.1",
		"@threlte/core": "8.5.11",
		"@threlte/extras": "9.15.0",
		"@threlte/rapier": "3.4.1",
		"@threlte/xr": "1.5.2",
		"@types/bun": "1.2.21",
		"@types/earcut": "^3.0.0",
		"@types/lodash-es": "4.17.12",
		"@types/node": "^25.6.0",
		"@types/three": "0.183.1",
		"@typescript-eslint/eslint-plugin": "8.56.1",
		"@typescript-eslint/parser": "8.56.1",
		"@viamrobotics/prime-core": "0.1.5",
		"@viamrobotics/sdk": "0.58.0",
		"@viamrobotics/svelte-sdk": "1.0.1",
		"@vitest/browser": "3.2.4",
		"@vitest/coverage-v8": "^3.2.4",
		"@zag-js/collapsible": "1.22.1",
		"@zag-js/floating-panel": "1.22.1",
		"@zag-js/popover": "1.22.1",
		"@zag-js/svelte": "1.22.1",
